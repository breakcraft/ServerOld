// Movement: decide whether to remain idle or to walk
def_int $walk_type = random(3);
if ($walk_type = 0) {
    // Idle – do nothing this cycle
} else if ($walk_type = 1) {
    npc_walk(movecoord(npc_coord, random(1), 0, random(1)));
} else {
    npc_walk(movecoord(npc_coord, sub(random(3), 1), 0, sub(random(3), 1)));
}

// Reset the timer for the next cycle (delay between 5 and 30 ticks)
def_int $next = add(5, random(25));
npc_settimer($next);
