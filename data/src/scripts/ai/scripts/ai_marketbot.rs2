[ai_spawn,goblin_unarmed1]
npc_settimer(5);  // Start the behavior loop after 5 ticks

[ai_timer,goblin_unarmed1]
def_int $say = random(12);
def_int $color = random(6);

// Use nested ifs to output a colorized message
if ($color = 0) {  // Red messages
    if ($say = 0) {
        npc_say("Selling coal! Cheap!");
    } else if ($say = 1) {
        npc_say("Buying iron bars!");
    } else if ($say = 2) {
        npc_say("Selling 10k willows");
    } else if ($say = 3) {
        npc_say("Buying death runes");
    } else if ($say = 4) {
        npc_say("Trade me for deals!");
    } else if ($say = 5) {
        npc_say("Selling feathers 5gp each!");
    } else if ($say = 6) {
        npc_say("Buying all runes!");
    } else if ($say = 7) {
        npc_say("B U Y I N G  S T E E L  B A R S");
    } else if ($say = 8) {
        npc_say("Selling lobster! PM me!");
    } else if ($say = 9) {
        npc_say("Buying pure essence!");
    } else if ($say = 10) {
        npc_say("Selling fire runes 10k!");
    } else {
        npc_say("Need GP? Sell me ur junk!");
    }
